# ── LLM provider (any OpenAI-compatible chat API) ──────────────────────────
# Default: Groq free tier — get a free key at https://console.groq.com/keys
LLM_API_KEY=gsk_...

# Provider base URL (optional; defaults to Groq)
#   Groq:        https://api.groq.com/openai/v1
#   OpenRouter:  https://openrouter.ai/api/v1        (free models end in ":free")
#   Gemini:      https://generativelanguage.googleapis.com/v1beta/openai
LLM_BASE_URL=https://api.groq.com/openai/v1

# Model ID (optional; defaults to llama-3.3-70b-versatile)
#   Groq:        llama-3.3-70b-versatile
#   OpenRouter:  meta-llama/llama-3.3-70b-instruct:free
#   Gemini:      gemini-2.0-flash
LLM_MODEL=llama-3.3-70b-versatile

# ── Server ──────────────────────────────────────────────────────────────────
# Port for the API server (optional; defaults to 3000)
PORT=3000

# Allowed CORS origin(s), comma-separated (optional; defaults to the Vite dev server)
CLIENT_ORIGIN=http://localhost:5173

# Set to "production" in production to suppress internal error details
NODE_ENV=development
